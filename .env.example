# ---- data-transform-service: variáveis de ambiente ----
# Copie para .env e ajuste conforme necessário.

# Porta do servidor gRPC
GRPC_PORT=50053

# Porta do servidor HTTP de métricas Prometheus + health check
METRICS_PORT=9091

# Salt usado na pseudonimização (hash do patient_id). Troque em produção.
PSEUDONYM_SALT=pspd-troque-este-salt

# Nível de log: debug | info | warn | error
LOG_LEVEL=info
